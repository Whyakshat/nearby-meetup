datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id           String   @id @default(uuid())
  name         String
  email        String   @unique
  password     String
  avatar       String?
  bio          String?
  interests    String   // stored as JSON string
  gender       String?
  isPrivate    Boolean  @default(false)
  blockedUsers String   // stored as JSON string of user IDs
  createdAt    DateTime @default(now())

  // Relations
  posts        Post[]
  meetups      Meetup[]
  sentRequests Request[] @relation("SentRequests")
  receivedReqs Request[] @relation("ReceivedRequests")
  sentMessages Message[] @relation("SentMessages")
  recvMessages Message[] @relation("ReceivedMessages")
}

model Post {
  id         String   @id @default(uuid())
  text       String?
  image      String?
  imageRatio String   @default("auto")
  authorId   String
  author     User     @relation(fields: [authorId], references: [id])
  isArchived Boolean  @default(false)
  timestamp  DateTime @default(now())
}

model Meetup {
  id                 String   @id @default(uuid())
  activity           String
  maxParticipants    Int
  joinedParticipants String   // stored as JSON string of user IDs
  authorId           String
  author             User     @relation(fields: [authorId], references: [id])
  status             String   @default("open")
  timestamp          DateTime @default(now())
}

model Request {
  id       String   @id @default(uuid())
  fromId   String
  toId     String
  from     User     @relation("SentRequests", fields: [fromId], references: [id])
  to       User     @relation("ReceivedRequests", fields: [toId], references: [id])
  activity String
  status   String   @default("pending") // pending, accepted, declined
  createdAt DateTime @default(now())
}

model Message {
  id         String   @id @default(uuid())
  requestId  String?
  senderId   String
  receiverId String
  sender     User     @relation("SentMessages", fields: [senderId], references: [id])
  receiver   User     @relation("ReceivedMessages", fields: [receiverId], references: [id])
  content    String
  timestamp  DateTime @default(now())
}
